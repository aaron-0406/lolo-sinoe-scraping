# SINOE — Sistema de Notificaciones Electrónicas (Poder Judicial del Perú)
# Copy to .env and fill with real values. NEVER commit .env.
#
# Hay dos modos. Setea SINOE_MULTITENANT_MODE según cual vas a usar y
# llena SOLO la sección correspondiente:
#
#   * Modo legacy / dev local  → CLI interactivo con tu propia casilla.
#     Comando: uv run lolo-sinoe login
#
#   * Modo multitenant / server → procesa N cuentas leídas de db_lolo,
#     descifra passwords con KMS, corre 24/7 en la laptop de operación.
#     Comando: uv run python -m lolo_sinoe.api

# ─────────────────────────────────────────────────────────────────────
# CAPTCHA — REQUERIDO en ambos modos. Al menos uno de los dos.
# ─────────────────────────────────────────────────────────────────────

# 2Captcha (recomendado): reusar API key del proyecto lolo-cej-scraping si aplica.
SINOE_TWOCAPTCHA_API_KEY=
# CapSolver: alternativa / fallback.
SINOE_CAPSOLVER_API_KEY=
# Orden de prueba — el primero configurado se usa primero.
SINOE_CAPTCHA_PROVIDER_ORDER=2captcha,capsolver

# ─────────────────────────────────────────────────────────────────────
# Modo activo
# ─────────────────────────────────────────────────────────────────────

# false = CLI legacy (dev). true = API server multitenant.
SINOE_MULTITENANT_MODE=false

# ─────────────────────────────────────────────────────────────────────
# Modo legacy / dev — solo si SINOE_MULTITENANT_MODE=false
# ─────────────────────────────────────────────────────────────────────

# Credenciales de TU casilla SINOE (para que el dev explore con la suya).
SINOE_CASILLA=
SINOE_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# Modo multitenant — solo si SINOE_MULTITENANT_MODE=true
# ─────────────────────────────────────────────────────────────────────

# DB (REQUERIDO en multitenant) — conecta directo al db_lolo del backend.
# Formato: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
#
# (a) Local — MySQL corriendo en tu laptop (mismo db_lolo que usa el backend
#     local). Reusá las credenciales de lolo-backend/.env (DB_USER, DB_PASSWORD,
#     DB_HOST=127.0.0.1, DB_PORT=3306, DB_NAME=db_lolo):
#     SINOE_DB_URL=mysql+pymysql://root:root@127.0.0.1:3306/db_lolo
#
# (b) POC — laptop apuntando a RDS prod (patrón actual mientras no hay EC2,
#     ver memoria project_scrapers_local_first):
#     SINOE_DB_URL=mysql+pymysql://lolo_sinoe_scraper:***@<rds-host>:3306/db_lolo
SINOE_DB_URL=mysql+pymysql://root:root@127.0.0.1:3306/db_lolo
SINOE_DB_POOL_MAX=10

# KMS — REQUERIDO para descifrar passwords de SINOE_ACCOUNT.
#
# ⚠️ IMPORTANTE: el BACKEND (lolo-backend) cifra los passwords cuando
# se crea una cuenta SINOE; el SCRAPER los descifra al sincronizar. Los
# DOS proyectos tienen que compartir la MISMA clave, pero los nombres
# de las variables son distintos:
#
#   Scraper (este repo, prefix SINOE_)    →  Backend (lolo-backend/.env)
#   ────────────────────────────────────     ──────────────────────────
#   SINOE_KMS_KEY_ID                       →  KMS_SINOE_KEY_ID
#   SINOE_KMS_FALLBACK_MASTER_KEY          →  KMS_FALLBACK_MASTER_KEY
#   SINOE_AWS_REGION                       →  AWS_REGION
#
# El valor (la string base64 de la fallback master key, o el ARN de la
# KMS key) DEBE SER EL MISMO en ambos `.env`. Si difieren, el scraper no
# puede descifrar lo que escribió el backend → "Access denied" / "decrypt
# failed" en el sync.
#
# Opción A (prod / staging con AWS): KMS Key ARN.
SINOE_KMS_KEY_ID=arn:aws:kms:us-west-2:<account>:key/<id>
SINOE_AWS_REGION=us-west-2
SINOE_AWS_PROFILE=viktoria-prod
# Alternativa: pasar creds explícitas en lugar de usar `aws configure --profile`.
# Si ambas están seteadas, tienen prioridad sobre el profile. Útil cuando ya
# tenés las creds del backend (`AWS_PUBLIC_KEY` / `AWS_SECRET_KEY`).
SINOE_AWS_ACCESS_KEY_ID=
SINOE_AWS_SECRET_ACCESS_KEY=
# Bucket S3 donde se suben los anexos. Tiene que ser el mismo que usa el
# backend (AWS_BUCKET_NAME). Default funciona si tu cuenta usa archivosstorage.
SINOE_AWS_BUCKET_NAME=archivosstorage
#
# Opción B (POC sin AWS): master key AES-GCM base64 32 bytes. Migrar a KMS
# antes de tener cliente externo. Generar con cualquiera de:
#   python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#   uv run python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#   openssl rand -base64 32
# Pegá la salida acá y TAMBIÉN en lolo-backend/.env como KMS_FALLBACK_MASTER_KEY.
# Si seteás esta, podés omitir SINOE_KMS_KEY_ID.
SINOE_KMS_FALLBACK_MASTER_KEY=

# Redis — queues internas (priority/monitor/initial). docker compose up -d redis.
SINOE_REDIS_URL=redis://localhost:6379

# Worker pool. Defaults laptop-friendly.
SINOE_WORKER_CONCURRENCY=2
SINOE_BROWSER_POOL_SIZE=2

# Bind del API local (health/metrics). Solo localhost por seguridad.
SINOE_API_BIND_HOST=127.0.0.1
SINOE_API_BIND_PORT=8001

# ─────────────────────────────────────────────────────────────────────
# Comunes a ambos modos
# ─────────────────────────────────────────────────────────────────────

# Browser
SINOE_HEADLESS=false
SINOE_NAV_TIMEOUT_MS=30000

# Retries
SINOE_CAPTCHA_MAX_RETRIES=3

# Logging
SINOE_LOG_LEVEL=INFO
SINOE_LOG_FORMAT=console

# URLs (override only if SINOE moves)
SINOE_LOGIN_URL=https://casillas.pj.gob.pe/sinoe/login.xhtml
